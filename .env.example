# ============================================================
# AI Traffic Congestion Predictor — environment configuration
# Copy to `.env` and fill in the secrets below.
# ============================================================

# ---- Database (hosted Supabase Postgres) -------------------
# Supabase project : traffic-management
# Project ref      : znlxbrhmxdwezcnjkens
# Region           : ap-south-1 (Mumbai)
#
# Get your database password from the Supabase dashboard:
#   Project Settings -> Database -> Connection string -> "Session/Transaction pooler"
#
# Transaction pooler (port 6543) -- recommended for FastAPI:
# DATABASE_URL should be stored in your local `.env` only. The real connection
# string has been removed from this example. Rotate the DB password immediately
# if this value was public.
DATABASE_URL=postgresql://postgres:<REDACTED_DB_PASSWORD>@<REDACTED_HOST>:6543/postgres
#
# Direct connection (port 5432) -- use only if the pooler is unavailable:
# DATABASE_URL=postgresql://postgres:<YOUR-DB-PASSWORD>@db.znlxbrhmxdwezcnjkens.supabase.co:5432/postgres

# ---- Supabase metadata (informational; not required to run) -
SUPABASE_URL=https://<REDACTED>.supabase.co
SUPABASE_ANON_KEY=<REDACTED_SUPABASE_ANON_KEY>

# ---- LLM (Groq -- free, fast inference) --------------------
# Get a key at https://console.groq.com/keys (free).
# Llama 3.3 70B is the default model; change in backend/services/chatbot.py if you want.
GROQ_API_KEY=<REDACTED_GROQ_API_KEY>
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Map provider (TomTom -- free 2500 req/day) ------------
# Get a key at https://developer.tomtom.com/ (free).
# This key is exposed to the browser via NEXT_PUBLIC_*; create a separate
# key with referer / IP restrictions for production.
NEXT_PUBLIC_TOMTOM_API_KEY=<REDACTED_TOMTOM_KEY>

# ---- Backend API -------------------------------------------
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000
LIVE_UPDATE_INTERVAL=30
MODEL_DIR=ml/artifacts

# Re-seed the synthetic data on container startup (true/false).
SEED_ON_STARTUP=false
# Re-train the model on container startup (true/false).
TRAIN_ON_STARTUP=false

# ---- Frontend (Next.js) ------------------------------------
# URL the Next.js BFF route handlers use to reach FastAPI.
# In docker-compose this is the service name; locally use localhost.
FASTAPI_URL=http://backend:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
